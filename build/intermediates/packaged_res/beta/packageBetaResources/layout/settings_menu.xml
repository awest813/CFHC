<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/textSettingsLead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Head Coach Career"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSettingsSublead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Shape the rules of your new coaching run before you choose a program."
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Show Player Potential" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxShowPotential" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Show Full Game Play by Play" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxShowFullGameLog" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Head Coach Career Mode (Fireable)" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxCareerMode" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Fountain of Youth Mode" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxNeverRetire" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:id="@+id/textPlayoffs" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable 12-Team Playoff" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxPlayoffs" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable TV Contracts" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxTV" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:id="@+id/textConfRealignment" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable Conf Realignment" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxConfRealignment" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:id="@+id/textAdvConfRealignment" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable Advanced Conf Realignment" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxAdvConfRealignment" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center_vertical" android:orientation="horizontal">
                <TextView android:id="@+id/textEnableProRel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Enable Promotion/Relegation" android:textColor="@color/textPrimary" android:textSize="14sp" android:textStyle="bold" />
                <CheckBox android:id="@+id/checkboxProRelegation" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button android:id="@+id/buttonCancelSettings" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginRight="6dp" android:layout_weight="1" android:background="@drawable/bg_action_secondary" android:text="Cancel" android:textAllCaps="false" android:textColor="@color/textPrimary" android:textStyle="bold" />
            <Button android:id="@+id/buttonOkSettings" android:layout_width="0dp" android:layout_height="48dp" android:layout_marginLeft="6dp" android:layout_weight="1" android:background="@drawable/bg_action_primary" android:text="OK" android:textAllCaps="false" android:textColor="@color/colorPrimaryDark" android:textStyle="bold" />
        </LinearLayout>

        <Button android:id="@+id/buttonGameEditor" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp" android:background="@drawable/bg_action_secondary" android:text="Game Editor (Beta)" android:textAllCaps="false" android:textColor="@color/textPrimary" android:textStyle="bold" />
        <Button android:id="@+id/buttonFixBowls" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_action_secondary" android:text="Fix Bowl Names" android:textAllCaps="false" android:textColor="@color/textPrimary" android:textStyle="bold" />
        <Button android:id="@+id/buttonProRel" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_action_secondary" android:text="Convert to Pro-Rel" android:textAllCaps="false" android:textColor="@color/textPrimary" android:textStyle="bold" />
        <Button android:id="@+id/buttonChangeTeams" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="18dp" android:background="@drawable/bg_action_secondary" android:text="Resign from Job" android:textAllCaps="false" android:textColor="@color/textPrimary" android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
