<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_mobile_row"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/textTeamStatsLeft"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.4"
        android:text="Label"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/textSecondary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textTeamStatsCenter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_weight="0.85"
        android:background="@drawable/bg_mobile_stat_chip"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="8dp"
        android:text="You"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/textPrimary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textTeamStatsRight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.85"
        android:gravity="end"
        android:text="Opponent"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="@color/accentGold"
        android:textStyle="bold" />
</LinearLayout>
