<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_surface"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_dialog_section"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textArchiveShellLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_mobile_chip"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="@string/dialog_shell_label"
            android:textAllCaps="true"
            android:textColor="@color/textPrimary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textArchiveShellTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/dialog_shell_archive_title"
            android:textColor="@color/textPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textArchiveShellSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/dialog_shell_archive_subtitle"
            android:textColor="@color/textSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <Spinner
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:id="@+id/spinnerBowlCCG"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_mobile_chip"
        android:padding="8dp" />

    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/bg_dialog_section"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textViewBowlCCGDialog"
            android:textColor="@color/textPrimary"
            android:textSize="13sp" />
    </ScrollView>


</LinearLayout>
