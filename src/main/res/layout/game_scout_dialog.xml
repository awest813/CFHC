<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollerGameScoutDialog"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_surface"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/gameScoutDialogLeft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="ha1"
                android:textColor="@color/accentGold"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/gameScoutDialogCenter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingRight="8dp"
                    android:text="ha3"
                    android:textColor="@color/textPrimary" />

                <TextView
                    android:id="@+id/gameScoutDialogRight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingLeft="8dp"
                    android:text="ha3"
                    android:textColor="@color/textPrimary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/textScoutOffenseStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Offense Strategy:"
                android:textColor="@color/accentGold"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerScoutOffenseStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_mobile_chip"
                android:padding="8dp" />

            <TextView
                android:id="@+id/textScoutDefenseStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Defense Strategy:"
                android:textColor="@color/accentGold"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerScoutDefenseStrategy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_mobile_chip"
                android:padding="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/gameScoutDialogBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:text="ha3"
            android:textColor="@color/textPrimary" />
    </LinearLayout>
</ScrollView>
