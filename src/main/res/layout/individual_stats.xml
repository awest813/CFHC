<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_mobile_row"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Player Name"
        android:textAppearance="@style/TextAppearance.Cfhc.ListRowHeadline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/textStat0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="Games"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowLabel" />

        <TextView
            android:id="@+id/textStat1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="Comp %"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowLabel" />

        <TextView
            android:id="@+id/textStat2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="Yds"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowLabel" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/textStat3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="TD"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowLabel" />

        <TextView
            android:id="@+id/textStat4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="Int"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowLabel" />

        <TextView
            android:id="@+id/textStat5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mobile_stat_chip"
            android:gravity="center"
            android:padding="8dp"
            android:text="Rating"
            android:textAppearance="@style/TextAppearance.Cfhc.StatRowValueAccent" />
    </LinearLayout>
</LinearLayout>
