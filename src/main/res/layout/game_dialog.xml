<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollerGameDialog"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_surface"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Spinner
            android:id="@+id/boxscoreMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_mobile_chip"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/gameDialogScoreAway"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="XX"
                    android:textColor="@color/textPrimary"
                    android:textSize="36sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/gameDialogScoreDash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:text="-"
                    android:textColor="@color/textMuted"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/gameDialogScoreHome"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="XX"
                    android:textColor="@color/textPrimary"
                    android:textSize="36sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/gameDialogScoreAwayName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="AWAY TEAM"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/gameDialogScoreDashName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:text="@"
                    android:textColor="@color/textMuted" />

                <TextView
                    android:id="@+id/gameDialogScoreHomeName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="HOME TEAM"
                    android:textColor="@color/textSecondary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TableLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dialog_section"
                android:padding="8dp"
                android:stretchColumns="1,2,3,4,5">

                <TableRow>
                    <TextView android:id="@+id/scoreboard" android:padding="8dp" android:text="Team" android:textColor="@color/accentGold" android:textStyle="bold" />
                    <TextView android:id="@+id/scoreQT1" android:padding="8dp" android:text="1" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/scoreQT2" android:padding="8dp" android:text="2" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/scoreQT3" android:padding="8dp" android:text="3" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/scoreQT4" android:padding="8dp" android:text="4" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/scoreOT" android:padding="8dp" android:text="OT" android:textColor="@color/textSecondary" />
                </TableRow>

                <TableRow>
                    <TextView android:id="@+id/teamAway" android:padding="8dp" android:text="Away Team" android:textColor="@color/textPrimary" android:textStyle="bold" />
                    <TextView android:id="@+id/awayQT1" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/awayQT2" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/awayQT3" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/awayQT4" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/awayOT" android:padding="8dp" android:text="N/A" android:textColor="@color/textPrimary" />
                </TableRow>

                <TableRow>
                    <TextView android:id="@+id/teamHome" android:padding="8dp" android:text="Home Team" android:textColor="@color/textPrimary" android:textStyle="bold" />
                    <TextView android:id="@+id/homeQT1" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/homeQT2" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/homeQT3" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/homeQT4" android:padding="8dp" android:text="X" android:textColor="@color/textPrimary" />
                    <TextView android:id="@+id/homeOT" android:padding="8dp" android:text="N/A" android:textColor="@color/textPrimary" />
                </TableRow>
            </TableLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Summary" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Summary" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Summary" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogQBLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Passing" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogQBCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Passing" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogQBRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Passing" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogRushLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Rushing" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogRushCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Rushing" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogRushRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Rushing" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogRecLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Receiving" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogRecCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Receiving" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogRecRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Receiving" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogDefLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Defense" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogDefCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Defense" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogDefRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Defense" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="vertical">
                <TextView android:id="@+id/gameDialogKickLeft" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Kicking" android:textColor="@color/accentGold" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:orientation="horizontal">
                    <TextView android:id="@+id/gameDialogKickCenter" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingRight="8dp" android:text="Home Kicking" android:textColor="@color/textSecondary" />
                    <TextView android:id="@+id/gameDialogKickRight" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="end" android:paddingLeft="8dp" android:text="Away Kicking" android:textColor="@color/textSecondary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/gameDialogBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:padding="12dp"
            android:text="Play by Play"
            android:textColor="@color/textPrimary"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
