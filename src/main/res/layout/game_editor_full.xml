<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dialog_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/editor_panel_title"
                android:textColor="@color/accentGold"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/editor_panel_subtitle"
                android:textColor="@color/textSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/editorHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/editor_warning"
                android:textColor="@color/textPrimary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/editor_select_conference"
                android:textColor="@color/accentGold"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/confList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_mobile_chip"
                android:padding="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/editor_select_team"
                android:textColor="@color/accentGold"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/teamList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_mobile_chip"
                android:padding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_section"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/editor_team_conf" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editTextChangeConf" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/editor_team_name" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editTextChangeName" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/editor_team_abbr" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editTextChangeAbbr" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/editor_head_coach" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editTextChangeHC" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/editor_location" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editLocation" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/editor_prestige" android:textColor="@color/accentGold" android:textStyle="bold" />
            <EditText android:id="@+id/editPrestige" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_mobile_chip" android:padding="10dp" android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonCancelChangeName"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_action_secondary"
                android:text="@string/editor_back"
                android:textAllCaps="false"
                android:textColor="@color/textPrimary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonOkChangeName"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_action_primary"
                android:text="@string/editor_save"
                android:textAllCaps="false"
                android:textColor="@color/colorPrimaryDark"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
