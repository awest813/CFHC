<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_mobile_panel"
    android:gravity="center_vertical"
    android:minHeight="72dp"
    android:orientation="horizontal"
    android:padding="10dp">

    <TextView
        android:id="@+id/gameScheduleLeft"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.85"
        android:paddingEnd="8dp"
        android:textColor="@color/textSecondary"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textSize="12sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/gameScheduleButtonList"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:layout_weight="1.4"
        android:background="@drawable/bg_action_secondary"
        android:textAllCaps="false"
        android:textColor="@color/textPrimary"
        android:textSize="13sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/gameScheduleRight"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_weight="0.85"
        android:background="@android:color/transparent"
        android:gravity="end|center_vertical"
        android:textAllCaps="false"
        android:textColor="@color/accentGold"
        android:textSize="12sp" />
</LinearLayout>
