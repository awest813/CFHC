<resources>

    <!-- Material 3 base; palette + status/nav bar; dynamic color layered in CfhcApplication on API 31+. -->
    <style name="AppTheme" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="android:windowBackground">@color/colorPrimaryDark</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppThemeLight" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/blueLight</item>
        <item name="colorOnSurface">@color/colorPrimaryDark</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:navigationBarColor">@color/surfacePrimary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Typography: dense sports-management readability (reference: premium dynasty sim UIs) -->
    <style name="TextAppearance.Cfhc.HeroTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:lineSpacingMultiplier">1.05</item>
    </style>

    <style name="TextAppearance.Cfhc.HeroBody" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Cfhc.SectionTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">19sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Cfhc.SectionBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Cfhc.HubTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Cfhc.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_primary_button</item>
        <item name="android:textColor">@color/blueDark</item>
        <item name="cornerRadius">22dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Cfhc.Button.Secondary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/surface_secondary_button</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Shared list rows & stat chips: one typography system (tabular lining figures on numeric-heavy lines). -->
    <style name="TextAppearance.Cfhc.ListRowPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRowExpandedPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRowExpandedSecondary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipAccentSmall" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/accentGold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipHubMetric" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipHubCaption" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipRosterMuted" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipRosterValue" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ChipRosterAccent" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/accentGold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRowHeadline" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRowCompactBold" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRankOrdinal" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRankTitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.ListRankStat" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/accentGold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.StatRowLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.StatRowValuePrimary" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.StatRowValueAccent" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/accentGold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.HubSummary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textSecondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Cfhc.ButtonCompactPrimary" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/blueDark</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <style name="TextAppearance.Cfhc.ButtonCompactSecondary" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.NewsRowHeadline" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/accentGold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Cfhc.NewsRowBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:textSize">13sp</item>
    </style>

</resources>
